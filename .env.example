NODE_ENV=development
PORT=3000

# Chemin base de données (automatique selon NODE_ENV)
# production : /data/database.sqlite
# development : ./database.sqlite

# Credentials admin (UN seul compte)
ADMIN_USERNAME=admin
# Générer avec : node -e "const b=require('bcryptjs');console.log(b.hashSync('votre_mdp',12))"
ADMIN_PASSWORD_HASH=$2a$12$...

# JWT
JWT_SECRET=remplacer_par_un_secret_fort_min_32_chars
JWT_EXPIRES_IN=8h

# CORS – origines autorisées (séparées par virgule)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
