# Production env vars (à configurer dans Render.com)
# NE PAS committer .env.production dans git

NODE_ENV=production
PORT=3000

# La DB sera lue depuis /data/database.sqlite (Persistent Volume)

# Credentials admin — REMPLACER par un mot de passe fort
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$Y9GJ.at.0cpo2CrvEF9/d.E2VCE8k5YxoZ3qLp4dBj9YtA7Uc.kdy

# JWT — REMPLACER par une clé secrète long et aléatoire
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_LONGUE_ALEATOIRE_MIN_32_CHARS
JWT_EXPIRES_IN=8h

# CORS — Autoriser le frontend Vercel
CORS_ORIGINS=https://supporter-v5-frontend.vercel.app,http://localhost:5173
